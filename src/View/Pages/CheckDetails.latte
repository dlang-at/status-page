{extends '../Layout/Base.latte'}
{parameters DlangAT\StatusPage\Model\Check $check}
{var $navGroup = 'checks'}
{var $title = $check->getTitle()}

{block main}
    {embed '../Components/CheckDetails/Summary.latte', check: $check}{/embed}
    {embed '../Components/CheckDetails/Stats.latte', check: $check}{/embed}
    {embed '../Components/CheckDetails/TLS.latte', check: $check}{/embed}
    {embed '../Components/CheckDetails/Domain.latte', check: $check}{/embed}
{/block}
