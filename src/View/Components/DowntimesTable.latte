{parameters DlangAT\StatusPage\Model\Downtime[] $downtimes}

<table class="table table-hover table-responsive table-sm table-striped align-middle">
    <thead>
    <tr>
        <th class="text-end">Start</th>
        <th class="text-end">End</th>
        <th class="text-end">Duration</th>
        <th class="text-start">Error details</th>
    </tr>
    </thead>
    <tbody>
    <tr n:foreach="$downtimes as $downtime">
        <td class="text-end font-monospace">{$downtime->startedAt | formatDateTime}</td>
        {if $downtime->endedAt !== null}
            <td class="text-end font-monospace">{$downtime->endedAt | formatDateTime}</td>
        {else}
            <td class="text-end"><i>ongoing</i></td>
        {/if}
        {if $downtime->duration !== null}
            <td class="text-end font-monospace">{$downtime->duration | formatDuration}</td>
        {else}
            <td class="text-end"><i>n/a</i></td>
        {/if}
        <td class="text-start text-truncate">{$downtime->error}</td>
    </tr>
    </tbody>
</table>
