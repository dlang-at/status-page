{parameters DlangAT\StatusPage\Model\Check[] $checks}
<section>
    <h2 class="visually-hidden">Services</h2>
    <section>
        <h3 class="visually-hidden">Alerts</h3>
        <div class="container-fluid g-0">
            <ul class="row list-unstyled g-2">
                {foreach $checks as $check}
                    {if !$check->isUpConfirmed()}
                        {embed 'DashboardEntry.latte', check: $check}{/embed}
                    {/if}
                {/foreach}
            </ul>
        </div>
    </section>
    <section>
        <h3 class="visually-hidden">Up</h3>
        <div class="container-fluid g-0">
            <ul class="row list-unstyled g-2">
                {foreach $checks as $check}
                    {if $check->isUpConfirmed()}
                        {embed 'DashboardEntry.latte', check: $check}{/embed}
                    {/if}
                {/foreach}
            </ul>
        </div>
    </section>
</section>
